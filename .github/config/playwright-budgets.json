{
  "$schema": "https://json-schema.org/draft-07/schema",
  "description": "Performance budgets for Playwright component tests",
  "version": "1.0.0",
  "budgets": {
    "tests": {
      "max": 120,
      "unit": "seconds",
      "failOnExceed": false,
      "warnOnExceed": true,
      "description": "Playwright component tests execution time"
    }
  }
}

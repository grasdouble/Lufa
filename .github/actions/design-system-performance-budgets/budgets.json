{
  "$schema": "https://json-schema.org/draft-07/schema",
  "description": "Performance budgets for the Lufa Design System",
  "version": "2.0.0",
  "budgets": {
    "bundle": {
      "description": "Total bundle size limits (JS + CSS)",
      "totalSize": {
        "max": 275,
        "unit": "KB",
        "failOnExceed": true
      },
      "components": {
        "javascript": {
          "description": "Main JS bundle (lufa-ui.mjs)",
          "tracked": true,
          "failOnExceed": false
        },
        "css": {
          "description": "Main CSS bundle (style.css)",
          "tracked": true,
          "failOnExceed": false
        }
      },
      "gzipped": {
        "max": 50,
        "unit": "KB",
        "failOnExceed": true
      }
    },
    "timing": {
      "description": "Build and validation timing budgets",
      "build": {
        "max": 30,
        "unit": "seconds",
        "failOnExceed": true,
        "description": "Total time for tokens + themes + main build"
      },
      "cssCascade": {
        "max": 1000,
        "unit": "milliseconds",
        "failOnExceed": false,
        "warnOnExceed": true,
        "description": "CSS cascade validation time (includes CLI startup)"
      }
    }
  },
  "metadata": {
    "lastUpdated": "2026-03-03",
    "action": ".github/actions/design-system-performance-budgets/action.yml",
    "notes": [
      "Bundle size budgets are for uncompressed files",
      "Gzipped size represents actual network transfer size",
      "CSS cascade time measures CLI validation performance",
      "Playwright test execution time budget is in .github/config/playwright-budgets.json"
    ]
  }
}

{
  "name": "@grasdouble/lufa_config_prettier",
  "version": "0.1.4",
  "private": false,
  "description": "",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./prettier.config.mjs"
    },
    "./prettier.config.mjs": {
      "import": "./prettier.config.mjs"
    }
  },
  "main": "prettier.config.mjs",
  "files": [
    "prettier.config.mjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "lint-staged": {
    "*.{js,mjs}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1"
  },
  "devDependencies": {
    "sort-package-json": "^3.6.1"
  },
  "peerDependencies": {
    "prettier": "^3.7.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}

{
  "name": "@grasdouble/lufa_microfrontend_main-container",
  "version": "0.6.15",
  "private": true,
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build -w",
    "dev": "vite",
    "lint": "eslint ./src",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash -c 'pnpm typecheck'"
    ],
    "package.json": [
      "sort-package-json"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@grasdouble/lufa_design-system": "workspace:^",
    "import-map-overrides": "^6.1.0",
    "single-spa": "^6.0.3"
  },
  "devDependencies": {
    "@grasdouble/lufa_config_eslint": "workspace:^",
    "@grasdouble/lufa_config_prettier": "workspace:^",
    "@grasdouble/lufa_config_tsconfig": "workspace:^",
    "@grasdouble/lufa_plugin_vite_vite-plugin-import-map-injector": "workspace:^",
    "@grasdouble/lufa_plugin_vite_vite-plugin-react-preamble": "workspace:^",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "sort-package-json": "^3.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-externalize-deps": "^0.10.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}

{
  "name": "@grasdouble/lufa_design-system-themes",
  "version": "1.0.1",
  "private": false,
  "description": "Lufa Design System - Theme variants (ocean, forest, etc.)",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./coffee.css": "./dist/coffee.css",
    "./cyberpunk.css": "./dist/cyberpunk.css",
    "./forest.css": "./dist/forest.css",
    "./matrix.css": "./dist/matrix.css",
    "./nordic.css": "./dist/nordic.css",
    "./ocean.css": "./dist/ocean.css",
    "./steampunk.css": "./dist/steampunk.css",
    "./sunset.css": "./dist/sunset.css",
    "./volcano.css": "./dist/volcano.css",
    "./volt.css": "./dist/volt.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm clean && tsx scripts/copy-themes.ts",
    "clean": "rm -rf dist",
    "lint": "eslint scripts --ext .ts",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "pnpm validate:template && pnpm validate:a11y",
    "validate:a11y:all": "lufa-ds-cli validate --a11y --dir src",
    "validate:one": "lufa-ds-cli validate",
    "validate:template": "tsx scripts/validate-template.ts",
    "validate:theme:all": "lufa-ds-cli validate --dir src",
    "validate:theme:coffee": "lufa-ds-cli validate src/coffee.css",
    "validate:theme:cyberpunk": "lufa-ds-cli validate src/cyberpunk.css",
    "validate:theme:forest": "lufa-ds-cli validate src/forest.css",
    "validate:theme:matrix": "lufa-ds-cli validate src/matrix.css",
    "validate:theme:nordic": "lufa-ds-cli validate src/nordic.css",
    "validate:theme:ocean": "lufa-ds-cli validate src/ocean.css",
    "validate:theme:steampunk": "lufa-ds-cli validate src/steampunk.css",
    "validate:theme:sunset": "lufa-ds-cli validate src/sunset.css",
    "validate:theme:volcano": "lufa-ds-cli validate src/volcano.css",
    "validate:theme:volt": "lufa-ds-cli validate src/volt.css",
    "validate:token-usage": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css",
    "validate:token-usage:unused": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css --unused",
    "validate:token-usage:verbose": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css --verbose"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts}": [
      "bash -c 'pnpm typecheck'"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@grasdouble/lufa_design-system-tokens": "workspace:^"
  },
  "devDependencies": {
    "@grasdouble/lufa_config_eslint": "workspace:^",
    "@grasdouble/lufa_config_prettier": "workspace:^",
    "@grasdouble/lufa_config_tsconfig": "workspace:^",
    "@grasdouble/lufa_design-system-cli": "workspace:^",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/node": "^25.1.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}

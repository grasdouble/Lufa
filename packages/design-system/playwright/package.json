{
  "name": "@grasdouble/lufa_design-system-playwright",
  "version": "1.2.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "main": "index.js",
  "scripts": {
    "compress-snapshots": "bash scripts/compress-snapshots-manual.sh",
    "docker:update-snapshots-linux": "bash scripts/docker-update-snapshots-linux.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "playwright test -c playwright-ct.config.ts",
    "test-ct": "playwright test -c playwright-ct.config.ts",
    "test-ct:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test-ct:update-snapshots": "playwright test -c playwright-ct.config.ts --update-snapshots=all && pnpm run compress-snapshots",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:token-usage": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css,.tsx,.ts",
    "validate:token-usage:unused": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css,.tsx,.ts --unused",
    "validate:token-usage:verbose": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css,.tsx,.ts --verbose",
    "validate-system": "bash scripts/validate-snapshot-system.sh"
  },
  "lint-staged": {
    "**/__snapshots__/**/*.png": "bash scripts/compress-snapshots-precommit.sh",
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash -c 'pnpm typecheck'"
    ],
    "package.json": [
      "sort-package-json"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@grasdouble/lufa_config_eslint": "workspace:^",
    "@grasdouble/lufa_config_prettier": "workspace:^",
    "@grasdouble/lufa_config_tsconfig": "workspace:^",
    "@grasdouble/lufa_design-system": "workspace:^",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "lucide-react": "^0.577.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sort-package-json": "^3.6.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.8.1"
}

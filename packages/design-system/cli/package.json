{
  "name": "@grasdouble/lufa_design-system-cli",
  "version": "1.1.0",
  "private": false,
  "description": "Lufa Design System - CLI tools for theme validation",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lufa-ds-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm clean && tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "validate:a11y": "node dist/cli.js a11y",
    "validate:token-usage": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css,.ts",
    "validate:token-usage:unused": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css,.ts --unused",
    "validate:token-usage:verbose": "pnpm --filter @grasdouble/lufa_design-system-tokens run validate:token-usage -- --dir $PWD --ext .css,.ts --verbose"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash -c 'pnpm typecheck'"
    ],
    "package.json": [
      "sort-package-json"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@grasdouble/lufa_design-system-tokens": "workspace:^",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "postcss": "^8.5.8",
    "postcss-value-parser": "^4.2.0"
  },
  "devDependencies": {
    "@grasdouble/lufa_config_eslint": "workspace:^",
    "@grasdouble/lufa_config_prettier": "workspace:^",
    "@grasdouble/lufa_config_tsconfig": "workspace:^",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "c8": "^10.1.3",
    "eslint": "^9.39.3",
    "prettier": "^3.8.1",
    "sort-package-json": "^3.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}

          "$value": "{primitive.color.yellow.900}",
          "$type": "color",
          "$description": "Active/pressed state for warning interactive elements - darkest shade for click feedback",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Active/pressed state for warning buttons",
              "modes": {
                "dark": "{primitive.color.yellow.200}",
                "high-contrast": "{primitive.color.hc.yellow}"
              },
              "themeable": true
            }
          }
        }
      },
      "info": {
        "default": {
          "$value": "{primitive.color.blue.700}",
          "$type": "color",
          "$description": "Info state color - informational messages, tips, neutral notifications",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Info messages, help icons, informational badges, neutral notifications",
              "modes": {
                "dark": "{primitive.color.blue.300}",
                "high-contrast": "{primitive.color.hc.blue}"
              },
              "themeable": true
            }
          }
        },
        "subtle": {
          "$value": "{primitive.color.blue.100}",
          "$type": "color",
          "$description": "Subtle info background for alert boxes and banners",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Info alert backgrounds, info banner backgrounds",
              "modes": {
                "dark": "{primitive.color.blue.900}",
                "high-contrast": "{primitive.color.blue.100}"
              },
              "themeable": true
            }
          }
        },
        "border": {
          "$value": "{primitive.color.blue.300}",
          "$type": "color",
          "$description": "Info border color for outlined elements",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Info alert borders, informational element borders",
              "modes": {
                "dark": "{primitive.color.blue.700}",
                "high-contrast": "{primitive.color.hc.blue}"
              },
              "themeable": true
            }
          }
        },
        "hover": {
          "$value": "{primitive.color.blue.800}",
          "$type": "color",
          "$description": "Hover state for info interactive elements - one shade darker than default for visible state change",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Hover state for info buttons and links",
              "modes": {
                "dark": "{primitive.color.blue.300}",
                "high-contrast": "{primitive.color.hc.blue}"
              },
              "themeable": true
            }
          }
        },
        "active": {
          "$value": "{primitive.color.blue.900}",
          "$type": "color",
          "$description": "Active/pressed state for info interactive elements - darkest shade for click feedback",
          "$extensions": {
            "lufa": {
              "category": "semantic",

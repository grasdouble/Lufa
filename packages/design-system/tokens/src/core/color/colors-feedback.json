{
  "core": {
    "feedback": {
      "success": {
        "default": {
          "$value": "{primitive.color.green.700}",
          "$type": "color",
          "$description": "Success state color - positive feedback, confirmations, completed actions",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Success messages, confirmation icons, positive badges, completed checkmarks",
              "modes": {
                "dark": "{primitive.color.green.400}",
                "high-contrast": "{primitive.color.hc.green}"
              },
              "themeable": true
            }
          }
        },
        "subtle": {
          "$value": "{primitive.color.green.100}",
          "$type": "color",
          "$description": "Subtle success background for alert boxes and banners",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Success alert backgrounds, success banner backgrounds",
              "modes": {
                "dark": "{primitive.color.green.900}",
                "high-contrast": "{primitive.color.green.100}"
              },
              "themeable": true
            }
          }
        },
        "border": {
          "$value": "{primitive.color.green.300}",
          "$type": "color",
          "$description": "Success border color for outlined elements",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Success alert borders, success input borders",
              "modes": {
                "dark": "{primitive.color.green.700}",
                "high-contrast": "{primitive.color.hc.green}"
              },
              "themeable": true
            }
          }
        },
        "hover": {
          "$value": "{primitive.color.green.800}",
          "$type": "color",
          "$description": "Hover state for success interactive elements - one shade darker than default for visible state change",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Hover state for success buttons and links",
              "modes": {
                "dark": "{primitive.color.green.300}",
                "high-contrast": "{primitive.color.hc.green}"
              },
              "themeable": true
            }
          }
        },
        "active": {
          "$value": "{primitive.color.green.900}",
          "$type": "color",
          "$description": "Active/pressed state for success interactive elements - darkest shade for click feedback",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Active/pressed state for success buttons",
              "modes": {
                "dark": "{primitive.color.green.200}",
                "high-contrast": "{primitive.color.hc.green}"
              },
              "themeable": true
            }
          }
        }
      },
      "error": {
        "default": {
          "$value": "{primitive.color.red.700}",
          "$type": "color",
          "$description": "Error state color - validation errors, destructive actions, critical warnings - meets WCAG AA on subtle error background",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Error messages, validation feedback, destructive action buttons, critical icons",
              "modes": {
                "dark": "{primitive.color.red.400}",
                "high-contrast": "{primitive.color.hc.red}"
              },
              "themeable": true
            }
          }
        },
        "subtle": {
          "$value": "{primitive.color.red.100}",
          "$type": "color",
          "$description": "Subtle error background for alert boxes and banners",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Error alert backgrounds, error banner backgrounds",
              "modes": {
                "dark": "{primitive.color.red.900}",
                "high-contrast": "{primitive.color.red.100}"
              },
              "themeable": true
            }
          }
        },
        "border": {
          "$value": "{primitive.color.red.500}",
          "$type": "color",
          "$description": "Error border color for outlined elements - meets WCAG 1.4.11 (3:1) on light backgrounds",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Error alert borders, invalid input borders",
              "modes": {
                "dark": "{primitive.color.red.700}",
                "high-contrast": "{primitive.color.hc.red}"
              },
              "themeable": true
            }
          }
        },
        "hover": {
          "$value": "{primitive.color.red.800}",
          "$type": "color",
          "$description": "Hover state for error/destructive interactive elements - one shade darker than default for visible state change",
          "$extensions": {
            "lufa": {
              "category": "semantic",
              "role": "feedback",
              "useCase": "Hover state for destructive buttons and error links",
              "modes": {
                "dark": "{primitive.color.red.300}",
                "high-contrast": "{primitive.color.hc.red}"
              },
              "themeable": true
            }
          }
        },
        "active": {
          "$value": "{primitive.color.red.900}",
          "$type": "color",
          "$description": "Active/pressed state for error/destructive interactive elements - darkest shade for click feedback",
          "$extensions": {
            "lufa": {
              "category": "semantic",

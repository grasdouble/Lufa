              "useCase": "Warning alert borders, caution element borders",
              "modes": {
                "dark": "{primitive.color.yellow.700}",
                "high-contrast": "{primitive.color.hc.yellow}"
              },
              "themeable": true
            }
          }
        },
        "hover": {
          "$value": "{primitive.color.yellow.800}",
          "$type": "color",
          "$description": "Hover state for warning interactive elements - one shade darker than default for visible state change",
          "$extensions": {
            "lufa": {

{
  "core": {
    "color": {
      "brand": {
        "primary": {
          "default": {
            "$value": "{primitive.color.blue.600}",
            "$type": "color",
            "$description": "Primary brand color used for main actions, links, and focus states. Represents trust and reliability.",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "action",
                "useCase": "Primary buttons, links, focus indicators, active navigation items",
                "modes": {
                  "dark": "{primitive.color.blue.400}",
                  "high-contrast": "{primitive.color.hc.blue}"
                },
                "themeable": true
              }
            }
          },
          "hover": {
            "$value": "{primitive.color.blue.700}",
            "$type": "color",
            "$description": "Primary brand hover state - darker shade for interactive feedback",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "action",
                "useCase": "Hover state for primary buttons and clickable elements",
                "modes": {
                  "dark": "{primitive.color.blue.300}",
                  "high-contrast": "{primitive.color.hc.blue}"
                },
                "themeable": true
              }
            }
          },
          "active": {
            "$value": "{primitive.color.blue.800}",
            "$type": "color",
            "$description": "Primary brand active/pressed state - darkest shade for click feedback",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "action",
                "useCase": "Active/pressed state for primary buttons",
                "modes": {
                  "dark": "{primitive.color.blue.600}",
                  "high-contrast": "{primitive.color.hc.blue}"
                },
                "themeable": true
              }
            }
          },
          "on": {
            "background": {
              "$value": "{primitive.color.hc.white}",
              "$type": "color",
              "$description": "Text color to use on primary brand background. Ensures WCAG AA contrast (4.5:1+) against primary brand color.",
              "$extensions": {
                "lufa": {
                  "category": "brand",
                  "role": "text-on-brand",
                  "useCase": "Text and icons on primary brand colored backgrounds (buttons, badges, banners)",
                  "a11y": "Must maintain 4.5:1 contrast ratio with brand primary color",
                  "modes": {
                    "dark": "{primitive.color.gray.900}",
                    "high-contrast": "{primitive.color.hc.white}"
                  },
                  "themeable": true
                }
              }
            }
          }
        },
        "secondary": {
          "default": {
            "$value": "{primitive.color.purple.600}",
            "$type": "color",
            "$description": "Secondary brand color used for accents, highlights, and secondary actions",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "action",
                "useCase": "Secondary buttons, badges, decorative accents, highlights",
                "modes": {
                  "dark": "{primitive.color.purple.400}",
                  "high-contrast": "{primitive.color.purple.600}"
                },
                "themeable": true
              }
            }
          },
          "hover": {
            "$value": "{primitive.color.purple.700}",
            "$type": "color",
            "$description": "Secondary brand hover state - darker shade for interactive feedback",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "action",
                "useCase": "Hover state for secondary buttons",
                "modes": {
                  "dark": "{primitive.color.purple.300}",
                  "high-contrast": "{primitive.color.purple.700}"
                },
                "themeable": true
              }
            }
          },
          "active": {
            "$value": "{primitive.color.purple.800}",
            "$type": "color",
            "$description": "Secondary brand active/pressed state - darkest shade for click feedback",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "action",
                "useCase": "Active/pressed state for secondary buttons",
                "modes": {
                  "dark": "{primitive.color.purple.500}",
                  "high-contrast": "{primitive.color.purple.800}"
                },
                "themeable": true
              }
            }
          },
          "on": {
            "background": {
              "$value": "{primitive.color.hc.white}",
              "$type": "color",
              "$description": "Text color to use on secondary brand background. Ensures WCAG AA contrast (4.5:1+) against secondary brand color.",
              "$extensions": {
                "lufa": {
                  "category": "brand",
                  "role": "text-on-brand",
                  "useCase": "Text and icons on secondary brand colored backgrounds (buttons, badges, highlights)",
                  "a11y": "Must maintain 4.5:1 contrast ratio with brand secondary color",
                  "modes": {
                    "dark": "{primitive.color.gray.900}",
                    "high-contrast": "{primitive.color.hc.white}"
                  },
                  "themeable": true
                }
              }
            }
          }
        },
        "accent": {
          "visited": {
            "$value": "{primitive.color.purple.600}",
            "$type": "color",
            "$description": "Visited link color - purple to indicate previously visited links",
            "$extensions": {
              "lufa": {
                "category": "brand",
                "role": "visited-link",
                "useCase": "Previously visited hyperlinks, navigation history tracking",
                "a11y": "Maintains WCAG AA contrast for visited links in all modes",
                "modes": {
                  "dark": "{primitive.color.purple.400}",
                  "high-contrast": "{primitive.color.hc.purple}"
                },
                "themeable": true
              }
            }
          }
        }
      }
    }
  }
}

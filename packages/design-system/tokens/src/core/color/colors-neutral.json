{
  "core": {
    "color": {
      "neutral": {
        "background": {
          "$value": "{primitive.color.gray.50}",
          "$type": "color",
          "$description": "Page background color - lightest neutral for main canvas",
          "$extensions": {
            "lufa": {
              "category": "neutral",
              "role": "content",
              "useCase": "Page backgrounds, root container backgrounds",
              "modes": {
                "dark": "{primitive.color.gray.900}",
                "high-contrast": "{primitive.color.hc.white}"
              },
              "themeable": true,
              "themeLevel": "starter"
            }
          }
        },
        "surface": {
          "default": {
            "$value": "{primitive.color.gray.100}",
            "$type": "color",
            "$description": "Surface color for cards, panels, and elevated elements",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Cards, modals, dropdowns, panels",
                "modes": {
                  "dark": "{primitive.color.gray.800}",
                  "high-contrast": "{primitive.color.gray.50}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "raised": {
            "$value": "{primitive.color.gray.200}",
            "$type": "color",
            "$description": "Raised surface color - slightly elevated above default, used as resting state for neutral solid buttons",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "action",
                "useCase": "Resting state for neutral solid buttons, slightly elevated surfaces",
                "modes": {
                  "dark": "{primitive.color.gray.700}",
                  "high-contrast": "{primitive.color.gray.200}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "hover": {
            "$value": "{primitive.color.gray.200}",
            "$type": "color",
            "$description": "Hover state for interactive surfaces",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "action",
                "useCase": "Hover state for list items, table rows, clickable cards",
                "modes": {
                  "dark": "{primitive.color.gray.700}",
                  "high-contrast": "{primitive.color.gray.200}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "active": {
            "$value": "{primitive.color.gray.300}",
            "$type": "color",
            "$description": "Active/pressed state for interactive surfaces - one shade darker than hover for click feedback",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "action",
                "useCase": "Active/pressed state for list items, table rows, clickable cards",
                "modes": {
                  "dark": "{primitive.color.gray.600}",
                  "high-contrast": "{primitive.color.gray.300}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          }
        },
        "border": {
          "default": {
            "$value": "{primitive.color.gray.500}",
            "$type": "color",
            "$description": "Default border color for dividers and element boundaries - meets WCAG 1.4.11 Non-text Contrast (3:1)",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Input borders, card borders, dividers, separators",
                "modes": {
                  "dark": "{primitive.color.gray.700}",
                  "high-contrast": "{primitive.color.hc.black}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "strong": {
            "$value": "{primitive.color.gray.600}",
            "$type": "color",
            "$description": "Stronger border color for emphasis or focus states - meets WCAG 1.4.11 Non-text Contrast (3:1)",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Emphasized borders, active input borders, strong dividers",
                "modes": {
                  "dark": "{primitive.color.gray.600}",
                  "high-contrast": "{primitive.color.hc.black}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          }
        },
        "text": {
          "primary": {
            "$value": "{primitive.color.gray.900}",
            "$type": "color",
            "$description": "Primary text color - highest contrast for body text and headings",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Body text, headings, primary labels",
                "modes": {
                  "dark": "{primitive.color.gray.50}",
                  "high-contrast": "{primitive.color.hc.black}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "secondary": {
            "$value": "{primitive.color.gray.600}",
            "$type": "color",
            "$description": "Secondary text color - medium contrast for supporting text",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Secondary labels, descriptions, captions, metadata",
                "modes": {
                  "dark": "{primitive.color.gray.400}",
                  "high-contrast": "{primitive.color.gray.700}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "tertiary": {
            "$value": "{primitive.color.gray.500}",
            "$type": "color",
            "$description": "Tertiary text color - lighter than secondary for optional, non-essential content. Use only for metadata, timestamps, and decorative labels where content is not required reading. Does not guarantee WCAG AA on light surfaces.",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Placeholder text, timestamps, optional information",
                "modes": {
                  "dark": "{primitive.color.gray.500}",
                  "high-contrast": "{primitive.color.gray.600}"
                },
                "note": "Intentionally below secondary (gray.600). Gray.500 is borderline contrast on light surfaces — reserve for non-essential content only.",
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          },
          "disabled": {
            "$value": "{primitive.color.gray.400}",
            "$type": "color",
            "$description": "Disabled text color - lowest contrast for inactive elements",
            "$extensions": {
              "lufa": {
                "category": "neutral",
                "role": "content",
                "useCase": "Disabled input text, disabled labels, inactive menu items",
                "modes": {
                  "dark": "{primitive.color.gray.600}",
                  "high-contrast": "{primitive.color.gray.500}"
                },
                "themeable": true,
                "themeLevel": "starter"
              }
            }
          }
        }
      }
    }
  }
}

{
  "semantic": {
    "effect": {
      "glow": {
        "box": {
          "none": {
            "$value": "none",
            "$type": "shadow",
            "$description": "No box glow effect (default for most components)",
            "$extensions": {
              "lufa": {
                "category": "effect",
                "useCase": "Components without glow effects, light themes",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          },
          "primary": {
            "default": {
              "$value": "none",
              "$type": "shadow",
              "$description": "Primary box glow effect for interactive elements (cards, buttons) - themeable",
              "$extensions": {
                "lufa": {
                  "category": "effect",
                  "useCase": "Cards, buttons in dark mode or themed experiences",
                  "themeable": true,
                  "themeLevel": "extended"
                }
              }
            },
            "hover": {
              "$value": "none",
              "$type": "shadow",
              "$description": "Enhanced primary box glow on hover - themeable",
              "$extensions": {
                "lufa": {
                  "category": "effect",
                  "useCase": "Hover state for cards and buttons",
                  "themeable": true,
                  "themeLevel": "extended"
                }
              }
            }
          },
          "focus": {
            "$value": {
              "offsetX": "0",
              "offsetY": "0",
              "blur": "0",
              "spread": "3px",
              "color": "{core.color.alpha.black.16}"
            },
            "$type": "shadow",
            "$description": "Focus ring glow for accessibility - neutral alpha token, themeable via theme overrides",
            "$extensions": {
              "lufa": {
                "category": "effect",
                "useCase": "Focus states for interactive elements like cards",
                "themeable": true,
                "themeLevel": "extended",
                "note": "Uses neutral alpha token instead of hardcoded brand color. Themes can override via their own token values."
              }
            }
          }
        },
        "text": {
          "none": {
            "$value": "none",
            "$type": "shadow",
            "$description": "No text glow effect (default)",
            "$extensions": {
              "lufa": {
                "category": "effect",
                "useCase": "Default text rendering",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          },
          "primary": {
            "default": {
              "$value": "none",
              "$type": "shadow",
              "$description": "Primary text glow for neon/cyberpunk effects - themeable",
              "$extensions": {
                "lufa": {
                  "category": "effect",
                  "useCase": "Text glow effects in themed buttons",
                  "themeable": true,
                  "themeLevel": "extended"
                }
              }
            },
            "hover": {
              "$value": "none",
              "$type": "shadow",
              "$description": "Enhanced text glow on hover - themeable",
              "$extensions": {
                "lufa": {
                  "category": "effect",
                  "useCase": "Hover state for text with glow effects",
                  "themeable": true,
                  "themeLevel": "extended"
                }
              }
            }
          }
        },
        "border": {
          "none": {
            "$value": "none",
            "$type": "shadow",
            "$description": "No border glow effect (default)",
            "$extensions": {
              "lufa": {
                "category": "effect",
                "useCase": "Default border rendering",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          },
          "focus": {
            "$value": {
              "offsetX": "0",
              "offsetY": "0",
              "blur": "0",
              "spread": "2px",
              "color": "{core.color.alpha.black.8}"
            },
            "$type": "shadow",
            "$description": "Border glow for focused inputs - neutral alpha token, themeable via theme overrides",
            "$extensions": {
              "lufa": {
                "category": "effect",
                "useCase": "Focus state for input fields",
                "themeable": true,
                "themeLevel": "extended",
                "note": "Uses neutral alpha token instead of hardcoded brand color. Themes can override via their own token values."
              }
            }
          }
        }
      }
    }
  }
}

{
  "semantic": {
    "ui": {
      "divider": {
        "$description": "Semantic divider tokens for dashed divider properties",
        "dash-size": {
          "$value": "{primitive.spacing.8}",
          "$type": "dimension",
          "$description": "Length of each dash segment in a dashed divider",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "divider",
              "useCase": "Dashed horizontal and vertical dividers",
              "themeable": true,
              "themeLevel": "extended"
            }
          }
        },
        "dash-gap": {
          "$value": "{primitive.spacing.12}",
          "$type": "dimension",
          "$description": "Total step between dash starts (dash + gap) in a dashed divider",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "divider",
              "useCase": "Dashed horizontal and vertical dividers",
              "themeable": true,
              "themeLevel": "extended"
            }
          }
        }
      }
    }
  }
}

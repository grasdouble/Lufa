{
  "semantic": {
    "ui": {
      "icon-size": {
        "$description": "Semantic icon size tokens for UI components",
        "xs": {
          "$value": "{primitive.icon-size.scale.xs}",
          "$type": "dimension",
          "$description": "Extra small icon size - compact UI elements",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "icon-size",
              "useCase": "Badges, small buttons, compact indicators",
              "themeable": true
            }
          }
        },
        "sm": {
          "$value": "{primitive.icon-size.scale.sm}",
          "$type": "dimension",
          "$description": "Small icon size - standard UI elements",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "icon-size",
              "useCase": "Button icons, input icons, default icon size",
              "themeable": true
            }
          }
        },
        "md": {
          "$value": "{primitive.icon-size.scale.md}",
          "$type": "dimension",
          "$description": "Medium icon size - emphasized UI elements",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "icon-size",
              "useCase": "Large buttons, card icons, section headers",
              "themeable": true
            }
          }
        },
        "lg": {
          "$value": "{primitive.icon-size.scale.lg}",
          "$type": "dimension",
          "$description": "Large icon size - prominent UI elements",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "icon-size",
              "useCase": "Modal headers, feature cards, hero sections",
              "themeable": true
            }
          }
        },
        "xl": {
          "$value": "{primitive.icon-size.scale.xl}",
          "$type": "dimension",
          "$description": "Extra large icon size - hero UI elements",
          "$extensions": {
            "lufa": {
              "category": "ui",
              "subcategory": "icon-size",
              "useCase": "Hero sections, landing pages, large feature displays",
              "themeable": true
            }
          }
        }
      }
    }
  }
}

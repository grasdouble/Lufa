{
  "semantic": {
    "interactive": {
      "border": {
        "default": {
          "$value": "{core.color.neutral.border.default}",
          "$type": "color",
          "$description": "Default border color for interactive elements in resting state",
          "$extensions": {
            "lufa": {
              "category": "interactive",
              "useCase": "Input borders, button outlines, card borders",
              "contrastWith": ["semantic.ui.background.page"],
              "contrastType": "ui",
              "themeable": true,
              "themeLevel": "extended"
            }
          }
        },
        "hover": {
          "$value": "{core.color.neutral.border.strong}",
          "$type": "color",
          "$description": "Border color when hovering over interactive elements - stronger emphasis",
          "$extensions": {
            "lufa": {
              "category": "interactive",
              "useCase": "Hover state borders for inputs and outlined buttons",
              "contrastWith": ["semantic.ui.background.page"],
              "contrastType": "ui",
              "themeable": true,
              "themeLevel": "extended"
            }
          }
        },
        "focus": {
          "$value": "{core.color.brand.primary.default}",
          "$type": "color",
          "$description": "Border color for focused interactive elements - indicates keyboard focus and accessibility",
          "$extensions": {
            "lufa": {
              "category": "interactive",
              "useCase": "Focus rings, focused input borders, keyboard navigation indicators",
              "contrastWith": ["semantic.ui.background.page"],
              "contrastType": "ui",
              "themeable": true,
              "themeLevel": "extended"
            }
          }
        },
        "disabled": {
          "$value": "{core.color.neutral.border.default}",
          "$type": "color",
          "$description": "Border color for disabled interactive elements - subtle indication of disabled state",
          "$extensions": {
            "lufa": {
              "category": "interactive",
              "useCase": "Disabled input borders, disabled button outlines",
              "themeable": true,
              "themeLevel": "extended"
            }
          }
        }
      }
    }
  }
}

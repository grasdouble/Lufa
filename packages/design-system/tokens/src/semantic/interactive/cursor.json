{
  "semantic": {
    "interactive": {
      "cursor": {
        "default": {
          "$value": "pointer",
          "$type": "other",
          "$description": "Default cursor for interactive elements (buttons, links, clickable items)",
          "$extensions": {
            "lufa": {
              "level": "semantic",
              "category": "interactive",
              "subcategory": "state",
              "useCase": "All clickable/interactive elements in their default state",
              "themeable": false,
              "modeAware": false
            }
          }
        },
        "disabled": {
          "$value": "not-allowed",
          "$type": "other",
          "$description": "Cursor for disabled interactive elements, indicating the action is not available",
          "$extensions": {
            "lufa": {
              "level": "semantic",
              "category": "interactive",
              "subcategory": "state",
              "useCase": "Disabled buttons, inputs, and controls",
              "themeable": false,
              "modeAware": false
            }
          }
        },
        "loading": {
          "$value": "wait",
          "$type": "other",
          "$description": "Cursor for elements in a loading/busy state, indicating the user should wait",
          "$extensions": {
            "lufa": {
              "level": "semantic",
              "category": "interactive",
              "subcategory": "state",
              "useCase": "Buttons or controls processing an async action",
              "themeable": false,
              "modeAware": false
            }
          }
        }
      }
    }
  }
}

{
  "semantic": {
    "interactive": {
      "action": {
        "primary": {
          "default": {
            "$value": "{core.color.brand.primary.default}",
            "$type": "color",
            "$description": "Primary action intent color - default state. Used for primary buttons, toggles, chips, and other actionable elements.",
            "$extensions": {
              "lufa": {
                "category": "interactive",
                "subcategory": "action",
                "useCase": "Primary button backgrounds, primary chip backgrounds, primary toggle tracks",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          },
          "hover": {
            "$value": "{core.color.brand.primary.hover}",
            "$type": "color",
            "$description": "Primary action intent color - hover state",
            "$extensions": {
              "lufa": {
                "category": "interactive",
                "subcategory": "action",
                "useCase": "Hover state for primary action elements",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          },
          "active": {
            "$value": "{core.color.brand.primary.active}",
            "$type": "color",
            "$description": "Primary action intent color - active/pressed state",
            "$extensions": {
              "lufa": {
                "category": "interactive",
                "subcategory": "action",
                "useCase": "Active/pressed state for primary action elements",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          },
          "on": {
            "$value": "{core.color.brand.primary.on.background}",
            "$type": "color",
            "$description": "Text/icon color on primary action backgrounds - ensures WCAG AA contrast",
            "$extensions": {
              "lufa": {
                "category": "interactive",
                "subcategory": "action",
                "useCase": "Text on primary buttons, icons on primary action surfaces",
                "a11y": "Must maintain 4.5:1 contrast ratio with primary action color",
                "themeable": true,
                "themeLevel": "extended"
              }
            }
          }
        },

{
  "component": {
    "popover": {
      "background": {
        "$value": "{semantic.ui.background.surface.default}",
        "$type": "color",
        "$description": "Popover background color",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover content background",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "text": {
        "$value": "{semantic.ui.text.primary}",
        "$type": "color",
        "$description": "Popover text color",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover content text",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "padding": {
        "$value": "{semantic.ui.spacing.default}",
        "$type": "dimension",
        "$description": "Popover content padding",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover body padding",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "border": {
        "$value": "{semantic.ui.border.default}",
        "$type": "color",
        "$description": "Popover border color",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover outline border",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "border-radius": {
        "$value": "{semantic.ui.border-radius.medium}",
        "$type": "dimension",
        "$description": "Popover border radius",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover corners",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "shadow": {
        "$value": "{semantic.ui.shadow.large}",
        "$type": "shadow",
        "$description": "Popover shadow for elevation",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover elevation above content",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "max-width": {
        "$value": "400px",
        "$type": "dimension",
        "$description": "Popover maximum width — intentionally raw (400px). Component-specific layout constraint not represented in the semantic spacing or container scale.",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover width constraint",
            "themeable": true,
            "themeLevel": "advanced",
            "note": "Layout constant — popover max-width is not covered by semantic container tokens."
          }
        }
      },
      "arrow": {
        "width": {
          "$value": "12px",
          "$type": "dimension",
          "$description": "Popover arrow width (base of triangle) — intentionally raw (12px). Geometric constant for CSS border-based arrow; not part of the spacing scale.",
          "$extensions": {
            "lufa": {
              "category": "popover",
              "useCase": "Popover arrow pointing to target",
              "themeable": true,
              "themeLevel": "advanced",
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        },
        "height": {
          "$value": "6px",
          "$type": "dimension",
          "$description": "Popover arrow height (triangle height) — intentionally raw (6px). Geometric constant for CSS border-based arrow; not part of the spacing scale.",
          "$extensions": {
            "lufa": {
              "category": "popover",
              "useCase": "Popover arrow projection",
              "themeable": true,
              "themeLevel": "advanced",
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        }
      },
      "offset": {
        "$value": "{semantic.ui.spacing.default}",
        "$type": "dimension",
        "$description": "Popover offset distance from target element",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Spacing between popover and trigger",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "z-index": {
        "$value": "{semantic.z-index.popover}",
        "$type": "number",
        "$description": "Popover z-index — references semantic popover layer",
        "$extensions": {
          "lufa": {
            "category": "popover",
            "useCase": "Popover layer stacking",
            "themeable": false
          }
        }
      }
    }
  }
}

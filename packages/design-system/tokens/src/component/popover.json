{
  "component": {
    "popover": {
      "background": {
        "$value": "{semantic.ui.background.surface}",
        "$type": "color",
        "$description": "Popover background color",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover content background",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "text": {
        "$value": "{semantic.ui.text.primary}",
        "$type": "color",
        "$description": "Popover text color",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover content text",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "padding": {
        "$value": "{semantic.ui.spacing.default}",
        "$type": "dimension",
        "$description": "Popover content padding",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover body padding",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "border": {
        "$value": "{semantic.ui.border.default}",
        "$type": "color",
        "$description": "Popover border color",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover outline border",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "border-radius": {
        "$value": "{semantic.ui.border-radius.medium}",
        "$type": "dimension",
        "$description": "Popover border radius",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover corners",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "shadow": {
        "$value": "{semantic.ui.shadow.large}",
        "$type": "shadow",
        "$description": "Popover shadow for elevation",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover elevation above content",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "max-width": {
        "$value": "400px",
        "$type": "dimension",
        "$description": "Popover maximum width",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover width constraint",
            "themeable": true,
            "modeAware": false,
            "note": "Layout constant — popover max-width is not covered by semantic container tokens."
          }
        }
      },
      "arrow": {
        "width": {
          "$value": "12px",
          "$type": "dimension",
          "$description": "Popover arrow width (base of triangle)",
          "$extensions": {
            "lufa": {
              "level": "component",
              "category": "popover",
              "useCase": "Popover arrow pointing to target",
              "themeable": true,
              "modeAware": false,
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        },
        "height": {
          "$value": "6px",
          "$type": "dimension",
          "$description": "Popover arrow height (triangle height)",
          "$extensions": {
            "lufa": {
              "level": "component",
              "category": "popover",
              "useCase": "Popover arrow projection",
              "themeable": true,
              "modeAware": false,
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        }
      },
      "offset": {
        "$value": "{semantic.ui.spacing.default}",
        "$type": "dimension",
        "$description": "Popover offset distance from target element",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Spacing between popover and trigger",
            "themeable": true,
            "modeAware": false
          }
        }
      },
      "z-index": {
        "$value": "9999",
        "$type": "number",
        "$description": "Popover z-index (high to appear above most content)",
        "$extensions": {
          "lufa": {
            "level": "component",
            "category": "popover",
            "useCase": "Popover layer stacking",
            "themeable": true,
            "modeAware": false,
            "note": "High z-index constant — must appear above all application layers including modals (1000+)."
          }
        }
      }
    }
  }
}

            "lufa": {
              "category": "button",
              "useCase": "Compact buttons, inline actions",
              "themeable": true
            }
          }
        },
        "md": {
          "$value": "{semantic.ui.spacing.default} {semantic.ui.spacing.comfortable}",
          "$type": "dimension",
          "$description": "Medium button padding (default size)",
          "$extensions": {
            "lufa": {
              "category": "button",
              "useCase": "Standard buttons, primary actions",
              "themeable": true
            }
          }
        },
        "lg": {
          "$value": "{semantic.ui.spacing.comfortable} {semantic.ui.spacing.spacious}",
          "$type": "dimension",
          "$description": "Large button padding (emphasized actions)",
          "$extensions": {
            "lufa": {
              "category": "button",

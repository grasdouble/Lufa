{
  "component": {
    "tooltip": {
      "background": {
        "$value": "{semantic.ui.text.primary}",
        "$type": "color",
        "$description": "Tooltip background color (typically dark for high contrast)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip background, popover background",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "text": {
        "$value": "{semantic.ui.background.surface.default}",
        "$type": "color",
        "$description": "Tooltip text color (inverted for contrast)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip text content",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "padding": {
        "block": {
          "$value": "{semantic.ui.spacing.compact}",
          "$type": "dimension",
          "$description": "Tooltip block-axis padding (top/bottom, 8px)",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip content padding (top/bottom)",
              "themeable": true,
              "themeLevel": "advanced"
            }
          }
        },
        "inline": {
          "$value": "{semantic.ui.spacing.default}",
          "$type": "dimension",
          "$description": "Tooltip inline-axis padding (left/right, 16px)",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip content padding (left/right)",
              "themeable": true,
              "themeLevel": "advanced"
            }
          }
        }
      },
      "border-radius": {
        "$value": "{semantic.ui.border-radius.small}",
        "$type": "dimension",
        "$description": "Tooltip border radius",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip corners",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "font-size": {
        "$value": "{semantic.ui.typography.caption}",
        "$type": "dimension",
        "$description": "Tooltip font size",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip text size",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "max-width": {
        "$value": "320px",
        "$type": "dimension",
        "$description": "Tooltip maximum width — intentionally raw (320px). Component-specific layout constraint not represented in the semantic spacing or container scale.",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip width constraint for long text",
            "themeable": true,
            "themeLevel": "advanced",
            "note": "Layout constant — tooltip max-width is not covered by semantic container tokens."
          }
        }
      },
      "shadow": {
        "$value": "{semantic.ui.shadow.medium}",
        "$type": "shadow",
        "$description": "Tooltip shadow for elevation",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip elevation above content",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "arrow": {
        "width": {
          "$value": "8px",
          "$type": "dimension",
          "$description": "Tooltip arrow width (base of triangle) — intentionally raw (8px). Geometric constant for CSS border-based arrow; not part of the spacing scale.",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip arrow pointing to target element",
              "themeable": true,
              "themeLevel": "advanced",
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        },
        "height": {
          "$value": "4px",
          "$type": "dimension",
          "$description": "Tooltip arrow height (triangle height) — intentionally raw (4px). Geometric constant for CSS border-based arrow; not part of the spacing scale.",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip arrow projection",
              "themeable": true,
              "themeLevel": "advanced",
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        }
      },
      "offset": {
        "$value": "{semantic.ui.spacing.compact}",
        "$type": "dimension",
        "$description": "Tooltip offset distance from target element",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Spacing between tooltip and trigger element",
            "themeable": true,
            "themeLevel": "advanced"
          }
        }
      },
      "animation": {
        "duration": {
          "$value": "{semantic.ui.transition.duration.fast}",
          "$type": "duration",
          "$description": "Tooltip fade-in/fade-out duration",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip appear/disappear animation",
              "themeable": true,
              "themeLevel": "advanced"
            }
          }
        },
        "delay": {
          "$value": "200ms",
          "$type": "duration",
          "$description": "Tooltip appearance delay (on hover) — intentionally raw (200ms). UX timing constant to prevent tooltip flicker on quick hover gestures; not part of the transition duration scale.",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Delay before tooltip appears on hover",
              "themeable": true,
              "themeLevel": "advanced",
              "note": "UX timing constant — 200ms is the minimum delay to prevent tooltip flicker on quick hover gestures."
            }
          }
        },
        "timing-function": {
          "$value": "{component.shared.transition.timing-function}",
          "$type": "cubicBezier",
          "$description": "Tooltip animation timing function",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Smooth animation curve",
              "themeable": true,
              "themeLevel": "advanced"
            }
          }
        }
      },
      "z-index": {
        "$value": "{semantic.z-index.popover}",
        "$type": "number",
        "$description": "Tooltip z-index — references semantic popover layer (tooltips share the popover stacking level)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip layer stacking",
            "themeable": false
          }
        }
      }
    }
  }
}

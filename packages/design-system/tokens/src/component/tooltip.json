{
  "component": {
    "tooltip": {
      "background": {
        "$value": "{semantic.ui.text.primary}",
        "$type": "color",
        "$description": "Tooltip background color (typically dark for high contrast)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip background, popover background",
            "themeable": true
          }
        }
      },
      "text": {
        "$value": "{semantic.ui.background.surface}",
        "$type": "color",
        "$description": "Tooltip text color (inverted for contrast)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip text content",
            "themeable": true
          }
        }
      },
      "padding": {
        "$value": "{semantic.ui.spacing.compact} {semantic.ui.spacing.default}",
        "$type": "dimension",
        "$description": "Tooltip padding (vertical horizontal)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip content padding",
            "themeable": true
          }
        }
      },
      "border-radius": {
        "$value": "{semantic.ui.border-radius.small}",
        "$type": "dimension",
        "$description": "Tooltip border radius",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip corners",
            "themeable": true
          }
        }
      },
      "font-size": {
        "$value": "{semantic.ui.typography.caption}",
        "$type": "dimension",
        "$description": "Tooltip font size",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip text size",
            "themeable": true
          }
        }
      },
      "max-width": {
        "$value": "320px",
        "$type": "dimension",
        "$description": "Tooltip maximum width to prevent overflow",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip width constraint for long text",
            "themeable": true,
            "note": "Layout constant — tooltip max-width is not covered by semantic container tokens."
          }
        }
      },
      "shadow": {
        "$value": "{semantic.ui.shadow.medium}",
        "$type": "shadow",
        "$description": "Tooltip shadow for elevation",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip elevation above content",
            "themeable": true
          }
        }
      },
      "arrow": {
        "width": {
          "$value": "8px",
          "$type": "dimension",
          "$description": "Tooltip arrow width (base of triangle)",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip arrow pointing to target element",
              "themeable": true,
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        },
        "height": {
          "$value": "4px",
          "$type": "dimension",
          "$description": "Tooltip arrow height (triangle height)",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip arrow projection",
              "themeable": true,
              "note": "Geometric triangle constant — CSS border-based arrow sizing requires explicit pixel values."
            }
          }
        }
      },
      "offset": {
        "$value": "{semantic.ui.spacing.compact}",
        "$type": "dimension",
        "$description": "Tooltip offset distance from target element",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Spacing between tooltip and trigger element",
            "themeable": true
          }
        }
      },
      "animation": {
        "duration": {
          "$value": "{semantic.ui.transition.duration.fast}",
          "$type": "duration",
          "$description": "Tooltip fade-in/fade-out duration",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Tooltip appear/disappear animation",
              "themeable": true
            }
          }
        },
        "delay": {
          "$value": "200ms",
          "$type": "duration",
          "$description": "Tooltip appearance delay (on hover)",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Delay before tooltip appears on hover",
              "themeable": true,
              "note": "UX timing constant — 200ms is the minimum delay to prevent tooltip flicker on quick hover gestures."
            }
          }
        },
        "timing-function": {
          "$value": "{component.shared.transition.timing-function}",
          "$type": "cubicBezier",
          "$description": "Tooltip animation timing function",
          "$extensions": {
            "lufa": {
              "category": "tooltip",
              "useCase": "Smooth animation curve",
              "themeable": true
            }
          }
        }
      },
      "z-index": {
        "$value": "9999",
        "$type": "number",
        "$description": "Tooltip z-index (high to appear above most content)",
        "$extensions": {
          "lufa": {
            "category": "tooltip",
            "useCase": "Tooltip layer stacking",
            "themeable": true,
            "note": "High z-index constant — must appear above all application layers including modals (1000+)."
          }
        }
      }
    }
  }
}

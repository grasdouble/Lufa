            "$extensions": {
              "lufa": {
                "category": "divider",
                "useCase": "Light structural separation, barely-there dividers",
                "themeable": true,
                "themeLevel": "advanced"
              }
            }
          },
          "thickness": {
            "$value": "{semantic.ui.border-width.thin}",
            "$type": "dimension",
            "$description": "Subtle emphasis thickness",
            "$extensions": {
              "lufa": {
                "category": "divider",
                "useCase": "Hairline dividers for minimal visual separation",
                "themeable": true,
                "themeLevel": "advanced"
              }
            }
          }
        },
        "default": {
          "color": {
            "$value": "{semantic.ui.border.default}",
            "$type": "color",
            "$description": "Default emphasis divider color (gray)",
            "$extensions": {
              "lufa": {
                "category": "divider",
                "useCase": "Standard section separators",
                "themeable": true,
                "themeLevel": "advanced"
              }
            }
          },
          "thickness": {
            "$value": "{semantic.ui.border-width.thin}",
            "$type": "dimension",
            "$description": "Default emphasis thickness",
            "$extensions": {
              "lufa": {
                "category": "divider",

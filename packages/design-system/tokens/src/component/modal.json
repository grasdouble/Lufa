{
  "component": {
    "modal": {
      "backdrop": {
        "background": {
          "$value": "{semantic.ui.overlay.backdrop}",
          "$type": "color",
          "$description": "Modal backdrop background (semi-transparent overlay)",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal backdrop, drawer overlays",
              "themeable": true
            }
          }
        },
        "blur": {
          "$value": "{semantic.ui.backdrop.blur}",
          "$type": "other",
          "$description": "Backdrop blur effect for modal overlay",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Backdrop-filter blur for modern modal overlays",
              "themeable": true
            }
          }
        }
      },
      "content": {
        "background": {
          "$value": "{semantic.ui.background.surface.default}",
          "$type": "color",
          "$description": "Modal content background",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal content area background",
              "themeable": true
            }
          }
        },
        "padding": {
          "$value": "{semantic.ui.spacing.comfortable}",
          "$type": "dimension",
          "$description": "Modal content padding",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal body padding",
              "themeable": true
            }
          }
        },
        "max-width": {
          "sm": {
            "$value": "400px",
            "$type": "dimension",
            "$description": "Small modal max width — intentionally raw (400px). Breakpoint-aligned modal width not covered by the semantic spacing scale.",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Compact modals, confirmation dialogs",
                "themeable": true,
                "note": "Layout constant — breakpoint-aligned modal widths are not covered by the semantic spacing scale."
              }
            }
          },
          "md": {
            "$value": "600px",
            "$type": "dimension",
            "$description": "Medium modal max width (default) — intentionally raw (600px). Breakpoint-aligned modal width not covered by the semantic spacing scale.",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Standard modals, form dialogs",
                "themeable": true,
                "note": "Layout constant — breakpoint-aligned modal widths are not covered by the semantic spacing scale."
              }
            }
          },
          "lg": {
            "$value": "800px",
            "$type": "dimension",
            "$description": "Large modal max width — intentionally raw (800px). Breakpoint-aligned modal width not covered by the semantic spacing scale.",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Large content modals, detailed forms",
                "themeable": true,
                "note": "Layout constant — breakpoint-aligned modal widths are not covered by the semantic spacing scale."
              }
            }
          },
          "xl": {
            "$value": "1200px",
            "$type": "dimension",
            "$description": "Extra large modal max width — intentionally raw (1200px). Breakpoint-aligned modal width not covered by the semantic spacing scale.",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Full-width modals, complex UIs",
                "themeable": true,
                "note": "Layout constant — breakpoint-aligned modal widths are not covered by the semantic spacing scale."
              }
            }
          }
        },
        "border-radius": {
          "$value": "{semantic.ui.border-radius.large}",
          "$type": "dimension",
          "$description": "Modal content border radius",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal content area corners",
              "themeable": true
            }
          }
        },
        "shadow": {
          "$value": "{semantic.ui.shadow.extra-large}",
          "$type": "shadow",
          "$description": "Modal content shadow for strong elevation",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal content elevation above backdrop",
              "themeable": true
            }
          }
        }
      },
      "header": {
        "padding": {
          "$value": "{semantic.ui.spacing.comfortable}",
          "$type": "dimension",
          "$description": "Modal header padding",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal header section",
              "themeable": true
            }
          }
        },
        "border": {
          "$value": "{semantic.ui.border.default}",
          "$type": "color",
          "$description": "Modal header bottom border",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Separator between header and body",
              "themeable": true
            }
          }
        }
      },
      "footer": {
        "padding": {
          "$value": "{semantic.ui.spacing.comfortable}",
          "$type": "dimension",
          "$description": "Modal footer padding",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal footer section (actions area)",
              "themeable": true
            }
          }
        },
        "border": {
          "$value": "{semantic.ui.border.default}",
          "$type": "color",
          "$description": "Modal footer top border",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Separator between body and footer",
              "themeable": true
            }
          }
        }
      },
      "close-button": {
        "size": {
          "$value": "32px",
          "$type": "dimension",
          "$description": "Close button size (width and height) — intentionally raw (32px). Fixed touch-target constant; minimum recommended interactive target size.",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal close button dimensions",
              "themeable": true,
              "note": "Fixed touch-target constant — 32px is the minimum recommended interactive target size."
            }
          }
        },
        "position": {
          "offset": {
            "$value": "{semantic.ui.spacing.default}",
            "$type": "dimension",
            "$description": "Close button offset from modal edges",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Close button positioning (top-right)",
                "themeable": true
              }
            }
          }
        },
        "color": {
          "default": {
            "$value": "{semantic.ui.text.secondary}",
            "$type": "color",
            "$description": "Close button icon color",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Close button icon",
                "themeable": true
              }
            }
          },
          "hover": {
            "$value": "{semantic.ui.text.primary}",
            "$type": "color",
            "$description": "Close button icon color on hover",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Close button hover state",
                "themeable": true
              }
            }
          }
        }
      },
      "animation": {
        "duration": {
          "enter": {
            "$value": "{semantic.ui.transition.duration.normal}",
            "$type": "duration",
            "$description": "Modal enter animation duration",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Modal fade-in and scale-up animation",
                "themeable": true
              }
            }
          },
          "exit": {
            "$value": "{semantic.ui.transition.duration.fast}",
            "$type": "duration",
            "$description": "Modal exit animation duration",
            "$extensions": {
              "lufa": {
                "category": "modal",
                "useCase": "Modal fade-out animation",
                "themeable": true
              }
            }
          }
        },
        "timing-function": {
          "$value": "{component.shared.transition.timing-function}",
          "$type": "cubicBezier",
          "$description": "Modal animation timing function",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Smooth animation curve for enter/exit",
              "themeable": true
            }
          }
        }
      },
      "z-index": {
        "backdrop": {
          "$value": "{semantic.z-index.modal-backdrop}",
          "$type": "number",
          "$description": "Modal backdrop z-index — references semantic modal-backdrop layer",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Backdrop layer stacking",
              "themeable": false
            }
          }
        },
        "content": {
          "$value": "{semantic.z-index.modal}",
          "$type": "number",
          "$description": "Modal content z-index — references semantic modal layer (above backdrop)",
          "$extensions": {
            "lufa": {
              "category": "modal",
              "useCase": "Modal content layer stacking",
              "themeable": false
            }
          }
        }
      }
    }
  }
}

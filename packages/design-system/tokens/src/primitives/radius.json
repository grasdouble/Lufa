{
  "primitive": {
    "radius": {
      "scale": {
        "none": {
          "$value": "0px",
          "$type": "dimension",
          "$description": "No rounding - sharp corners",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Square elements, strictly geometric design"
            }
          }
        },
        "sm": {
          "$value": "2px",
          "$type": "dimension",
          "$description": "Small radius - slightly rounded corners",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Badges, tags, small interface elements"
            }
          }
        },
        "base": {
          "$value": "4px",
          "$type": "dimension",
          "$description": "Base radius - standard rounding for most elements",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Buttons, inputs, standard cards"
            }
          }
        },
        "md": {
          "$value": "6px",
          "$type": "dimension",
          "$description": "Medium radius - more pronounced rounding",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Featured cards, panels"
            }
          }
        },
        "lg": {
          "$value": "8px",
          "$type": "dimension",
          "$description": "Large radius - generous rounding",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Modals, large cards, important surfaces"
            }
          }
        },
        "xl": {
          "$value": "12px",
          "$type": "dimension",
          "$description": "Extra large radius - very pronounced rounding",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Large surfaces, modern design"
            }
          }
        },
        "2xl": {
          "$value": "16px",
          "$type": "dimension",
          "$description": "2X Extra large radius - highly pronounced rounding",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Modal dialogs, hero cards, large panels, prominent components"
            }
          }
        },
        "full": {
          "$value": "9999px",
          "$type": "dimension",
          "$description": "Full radius - perfect circle or pill shape",
          "$extensions": {
            "lufa": {
              "category": "radius",
              "useCase": "Avatars, pill buttons, circular elements"
            }
          }
        }
      }
    }
  }
}

{
  "primitive": {
    "typography": {
      "font-size": {
        "xs": {
          "$value": "12px",
          "$type": "dimension",
          "$description": "Extra small font size - used for tiny labels, footnotes",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Secondary labels, notes, timestamps"
            }
          }
        },
        "sm": {
          "$value": "14px",
          "$type": "dimension",
          "$description": "Small font size - used for secondary text, descriptions",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Secondary text, short descriptions"
            }
          }
        },
        "base": {
          "$value": "16px",
          "$type": "dimension",
          "$description": "Base font size - default size for body text",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Body text, standard paragraphs"
            }
          }
        },
        "lg": {
          "$value": "18px",
          "$type": "dimension",
          "$description": "Large font size - used for emphasized text",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Emphasized text, lead paragraphs"
            }
          }
        },
        "xl": {
          "$value": "20px",
          "$type": "dimension",
          "$description": "Extra large font size - used for subtitles",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Subtitles, level 5-6 headings"
            }
          }
        },
        "2xl": {
          "$value": "clamp(1.25rem, 1rem + 1vw, 1.5rem)",
          "$type": "dimension",
          "$description": "2x extra large font size - fluid scaling from mobile to desktop",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Level 4 headings"
            }
          }
        },
        "3xl": {
          "$value": "clamp(1.5rem, 1.25rem + 1vw, 1.875rem)",
          "$type": "dimension",
          "$description": "3x extra large font size - fluid scaling from mobile to desktop",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Level 3 headings"
            }
          }
        },
        "4xl": {
          "$value": "clamp(1.75rem, 1.5rem + 1.25vw, 2.25rem)",
          "$type": "dimension",
          "$description": "4x extra large font size - fluid scaling from mobile to desktop",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Level 2 headings"
            }
          }
        },
        "5xl": {
          "$value": "clamp(2rem, 1.5rem + 2vw, 3rem)",
          "$type": "dimension",
          "$description": "5x extra large font size - fluid scaling from mobile to desktop",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Level 1 headings, hero titles"
            }
          }
        },
        "6xl": {
          "$value": "clamp(2.5rem, 2rem + 2.5vw, 3.75rem)",
          "$type": "dimension",
          "$description": "6x extra large font size - fluid scaling for hero headlines and featured content",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Hero headlines, featured content, large page titles"
            }
          }
        },
        "7xl": {
          "$value": "clamp(3rem, 2.5rem + 3vw, 4.5rem)",
          "$type": "dimension",
          "$description": "7x extra large font size - fluid scaling for marketing hero sections",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Marketing hero sections, landing page headlines, large announcements"
            }
          }
        },
        "8xl": {
          "$value": "clamp(4rem, 3rem + 4vw, 6rem)",
          "$type": "dimension",
          "$description": "8x extra large font size - fluid scaling for display text and brand impact moments (scales from 400px+ viewport)",
          "$extensions": {
            "lufa": {
              "category": "typography",
              "useCase": "Display text, brand impact moments, decorative large text"
            }
          }
        }
      }
    }
  }
}

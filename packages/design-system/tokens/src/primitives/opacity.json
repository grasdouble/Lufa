{
  "primitive": {
    "opacity": {
      "scale": {
        "disabled": {
          "$value": "0.38",
          "$type": "number",
          "$description": "Opacity for disabled states (Material Design standard - 38%)",
          "$extensions": {
            "lufa": {
              "category": "opacity",
              "useCase": "Disabled buttons, inputs, and controls"
            }
          }
        },
        "placeholder": {
          "$value": "0.5",
          "$type": "number",
          "$description": "Opacity for placeholder elements (50%)",
          "$extensions": {
            "lufa": {
              "category": "opacity",
              "useCase": "Input placeholders, empty state illustrations"
            }
          }
        },
        "loading": {
          "$value": "0.6",
          "$type": "number",
          "$description": "Opacity for loading states (60%)",
          "$extensions": {
            "lufa": {
              "category": "opacity",
              "useCase": "Skeleton loaders, loading placeholders"
            }
          }
        }
      }
    }
  }
}

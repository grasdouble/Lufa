{
  "name": "@grasdouble/lufa_design-system-tokens",
  "version": "1.2.1",
  "private": false,
  "description": "Lufa Design System - Semantic design tokens (colors, spacing, typography, etc.)",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/tokens-values.json",
    "./tokens.css": "./dist/tokens.css",
    "./values": "./dist/tokens-values.json",
    "./metadata": "./dist/tokens-metadata.json",
    "./merged": "./dist/tokens-source-merged.json",
    "./themeable": "./dist/themeable-tokens.css",
    "./themeable-starter": "./dist/themeable-tokens-starter.css",
    "./themeable-extended": "./dist/themeable-tokens-extended.css",
    "./themeable-advanced": "./dist/themeable-tokens-advanced.css"
  },
  "main": "./dist/tokens-values.json",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm validate:tokens",
    "build": "pnpm clean && style-dictionary build --config ./style-dictionary.config.js && pnpm check:size && pnpm merge:tokens",
    "check:size": "node scripts/check-css-size.mjs",
    "clean": "rm -rf dist",
    "merge:tokens": "node scripts/merge-tokens.mjs",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "pnpm test:validator && pnpm test:wcag",
    "test:validator": "node build/validators/token-consistency.test.js",
    "test:wcag": "node build/utils/wcag-contrast.test.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "validate:token-usage": "node scripts/validate-token-usage.js",
    "validate:tokens": "node build/validators/token-consistency.js"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{ts}": [
      "bash -c 'pnpm typecheck'"
    ],
    "package.json": [
      "sort-package-json"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@grasdouble/lufa_config_eslint": "workspace:^",
    "@grasdouble/lufa_config_prettier": "workspace:^",
    "@grasdouble/lufa_config_tsconfig": "workspace:^",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "glob": "^13.0.6",
    "prettier": "^3.8.1",
    "sort-package-json": "^3.6.1",
    "style-dictionary": "^5.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
